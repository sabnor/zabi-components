{
  "name": "zabi-components",
  "version": "7.0.1",
  "description": "Svelte 5 UI components with TypeScript and Tailwind CSS v4. Accessible, easy to theme, works with SSR.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "svelte": "./dist/index.js"
    },
    "./atoms": {
      "types": "./dist/atoms/index.d.ts",
      "import": "./dist/atoms/index.js",
      "svelte": "./dist/atoms/index.js"
    },
    "./molecules": {
      "types": "./dist/molecules/index.d.ts",
      "import": "./dist/molecules/index.js",
      "svelte": "./dist/molecules/index.js"
    },
    "./organisms": {
      "types": "./dist/organisms/index.d.ts",
      "import": "./dist/organisms/index.js",
      "svelte": "./dist/organisms/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./lib/ssr-safe": {
      "types": "./dist/routes/lib/ssr-safe.ts",
      "import": "./dist/routes/lib/ssr-safe.ts"
    },
    "./lib/variant-utils": {
      "types": "./dist/routes/lib/variant-utils.ts",
      "import": "./dist/routes/lib/variant-utils.ts"
    },
    "./dist/zabi-components.css": "./dist/zabi-components.css",
    "./dist/zabi-components-colors.css": "./dist/zabi-components-colors.css",
    "./dist/zabi-components-theme.css": "./dist/zabi-components-theme.css",
    "./dist/zabi-components-theme-only.css": "./dist/zabi-components-theme-only.css",
    "./dist/zabi-components-theme-dark.css": "./dist/zabi-components-theme-dark.css",
    "./dist/zabi-components-theme-dark-only.css": "./dist/zabi-components-theme-dark-only.css",
    "./theme": "./dist/zabi-components-theme.css",
    "./theme-only": "./dist/zabi-components-theme-only.css",
    "./theme-dark": "./dist/zabi-components-theme-dark.css",
    "./theme-dark-only": "./dist/zabi-components-theme-dark-only.css",
    "./colors": "./dist/zabi-components-colors.css",
    "./css": "./dist/zabi-components.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "THEME.md",
    "THEMING.md",
    "docs/theme-imports.md",
    "docs/lucide-icons.md",
    "scripts/fix-lucide-svelte-icon-dts.js"
  ],
  "keywords": [
    "svelte",
    "svelte5",
    "sveltekit",
    "components",
    "ui",
    "typescript",
    "tailwind",
    "runes",
    "ssr"
  ],
  "author": "Zabi Components Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sabnor/zabi-components.git"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run build:types",
    "build:components": "svelte-package -o dist --input src/components",
    "build:lib-files": "mkdir -p dist/routes/lib dist/types && cp src/components/util/ssr-safe.ts dist/routes/lib/ && cp src/routes/lib/variant-utils.ts dist/routes/lib/ && cp src/components/util/focus-utils.ts dist/routes/lib/ && cp src/components/types/variants.ts dist/types/ && cp src/components/types/page.types.ts dist/types/",
    "build:fix-imports": "node scripts/fix-package-imports.js",
    "build:lib": "npm run build:css && npm run build:components && npm run build:lib-files && npm run build:fix-imports && npm run build:types && npm run build:css && node scripts/verify-build.js",
    "sync:tokens": "node scripts/sync-theme-tokens.js",
    "build:css": "npm run sync:tokens && node scripts/build-css.js && node scripts/validate-theme.js",
    "check:tokens": "node scripts/check-token-violations.js",
    "build:types": "tsc --project tsconfig.lib.json && cp dist/components/util/focus-utils.d.ts dist/routes/lib/ && node scripts/emit-components-types-runtime.js",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json && node scripts/check-component-imports.js && node scripts/check-layout-width.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:playwright": "npm run test:e2e",
    "test:themes": "node --test tests/theme-output.test.js",
    "prepublishOnly": "npm run build:lib",
    "publish:npm": "npm publish --access public --registry https://registry.npmjs.org/",
    "postinstall": "node scripts/fix-lucide-svelte-icon-dts.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/sveltekit": "^10.2.19",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.47.2",
    "@sveltejs/package": "^2.5.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.5",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.2",
    "autoprefixer": "^10.4.17",
    "culori": "^4.0.2",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.35",
    "storybook": "^10.2.19",
    "svelte": "^5.43.8",
    "svelte-check": "^4.3.1",
    "tailwindcss": "^4.1.13",
    "typescript": "~5.8.3",
    "vite": "^7.1.6",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@lucide/svelte": "^0.544.0"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "react": "^18.0.0",
    "svelte": "^5.43.8"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": false
    },
    "@sveltejs/kit": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "overrides": {
    "cookie": "^0.7.0"
  },
  "svelte": "./dist/index.js",
  "ssr": true
}
